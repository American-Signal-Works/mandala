{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "globalEnv": [
    "NEXT_PUBLIC_SUPABASE_URL",
    "NEXT_PUBLIC_SUPABASE_ANON_KEY",
    "SUPABASE_SERVICE_ROLE_KEY",
    "NEXT_PUBLIC_SITE_URL",
    "PLAYWRIGHT_BASE_URL",
    "CI"
  ],
  "globalPassThroughEnv": [
    "AI_GATEWAY_API_KEY",
    "VERCEL_OIDC_TOKEN",
    "MANDALA_CONVERSATIONAL_PARSER_ENABLED",
    "MANDALA_CONTROL_PARSER_MODEL",
    "MANDALA_TEST_AGENT_ENABLED",
    "MANDALA_TEST_AGENT_MODEL",
    "MANDALA_CONTROL_INPUT_HASH_KEY",
    "MANDALA_CONTROL_BINDING_SECRET",
    "MANDALA_WORKFLOW_DATABASE_URL",
    "MANDALA_SKILLS_DIRECTORY",
    "INVITATION_TOKEN_SECRET",
    "EMAIL_PAYLOAD_RESOLVER_SECRET",
    "AUTH_PENDING_SESSION_SECRET",
    "ACCOUNT_DELETION_WORKER_SECRET",
    "CONTEXT_INDEX_WORKER_SECRET",
    "CONNECTOR_SYNC_WORKER_SECRET",
    "SIGNAL_DISPATCH_WORKER_SECRET",
    "SHIPHERO_ACCESS_TOKEN",
    "SHIPHERO_REFRESH_TOKEN",
    "SHIPHERO_API_KEY",
    "TRELLO_KEY",
    "TRELLO_TOKEN",
    "CRON_SECRET",
    "VERCEL_REGION",
    "CONTEXT_RETRIEVAL_ENABLED",
    "SUPERMEMORY_API_KEY",
    "EMAIL_PAYLOAD_RESOLVER_URL",
    "DELIVERY_WORKER_SECRET",
    "LANGSMITH_TRACING",
    "LANGSMITH_API_KEY",
    "LANGSMITH_PROJECT",
    "LANGSMITH_HIDE_INPUTS",
    "LANGSMITH_HIDE_OUTPUTS"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "format": {
      "dependsOn": ["^format"]
    },
    "typecheck": {
      "dependsOn": ["^build", "^typecheck"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": ["^build"]
    }
  }
}
