{
  "name": "@workspace/cli",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "bin": {
    "mandala": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && chmod +x dist/index.js",
    "lint": "eslint .",
    "pretest": "pnpm --dir ../.. --filter @workspace/control-plane build && pnpm build",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.105.1",
    "@workspace/control-plane": "workspace:*",
    "cli-table3": "0.6.5",
    "ink": "7.1.0",
    "ink-text-input": "6.0.0",
    "react": "^19.2.5",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^25.1.0",
    "@types/react": "^19.2.14",
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "eslint": "^9.39.2",
    "ink-testing-library": "4.0.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=22"
  },
  "os": [
    "darwin",
    "linux"
  ],
  "files": [
    "dist"
  ]
}
