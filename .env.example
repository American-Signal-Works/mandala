# Supabase — fill in from `supabase status` (local) or your project dashboard (prod)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Public site URL for OAuth + email-link redirects (production must set this)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Resend/Supabase Auth email (server-side only; do not expose as NEXT_PUBLIC_*)
# Production Resend sending requires a verified domain/subdomain.
RESEND_API_KEY=
SEND_EMAIL_HOOK_SECRET=
RESEND_AUTH_EMAIL_FROM_ADDRESS=
SUPABASE_AUTH_SEND_EMAIL_HOOK_URI=
SUPABASE_AUTH_SMTP_ADMIN_EMAIL=
SUPABASE_AUTH_SMTP_SENDER_NAME=Mandala

# Sentry (optional — leave blank in dev to disable error reporting)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# Optional conversational control parser (server-side only)
MANDALA_CONVERSATIONAL_PARSER_ENABLED=false
MANDALA_CONTROL_PARSER_MODEL=openai/gpt-5.4-mini
MANDALA_CONTROL_INPUT_HASH_KEY=
MANDALA_CONTROL_BINDING_SECRET=
AI_GATEWAY_API_KEY=
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=mandala-control-plane
LANGSMITH_HIDE_INPUTS=true
LANGSMITH_HIDE_OUTPUTS=true
